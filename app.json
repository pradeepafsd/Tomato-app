{
  "expo": {
    "name": "Tomato",
    "slug": "Tomato-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#dc2626"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.pradeepa.tomatoapp",
      "adaptiveIcon": {
        "backgroundColor": "#dc2626",
        "foregroundImage": "./assets/images/icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "8d5817ae-2e3b-42fc-b23a-ec386237fcdb"
      }
    }
  }
}
